// cartridge.cafe — lean schema: worlds, versions, tokens, flags + auth.
// Plots & stakes land with the hub. Tournament tables land with the vote module.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  status        UserStatus @default(ACTIVE)
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts      Account[]
  sessions      Session[]
  ownedSpaces   PlayerSpace[]  @relation("OwnedSpaces")
  spaceVersions SpaceVersion[]
  spaceFlags    SpaceFlag[]
  companions    Companion[]    @relation("CompanionOwners")
  passkeys      Passkey[]      @relation("UserPasskeys")
  builders      Builder[]      @relation("BuilderOwners")
}
// (follows live in the CafeFollow table, created via raw SQL in lib/notify.ts —
//  the cafe's community layer is intentionally not modeled in Prisma)

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserStatus {
  ACTIVE
  BANNED
  DELETED
}

model PlayerSpace {
  id          String       @id @default(cuid())
  slug        String       @unique // URL-friendly name, e.g. "galens-world"
  name        String // Display name
  ownerId     String
  owner       User         @relation("OwnedSpaces", fields: [ownerId], references: [id], onDelete: Cascade)
  snapshot    Json? // SceneSnapshot as JSONB
  description String?
  isPublic    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tokens      SpaceToken[]
  buildJobs   BuildJob[]

  // Nested space hierarchy
  parentSpaceId String?
  parentSpace   PlayerSpace?  @relation("SpaceChildren", fields: [parentSpaceId], references: [id], onDelete: SetNull)
  childSpaces   PlayerSpace[] @relation("SpaceChildren")

  // World history + governance
  versions SpaceVersion[]
  flags    SpaceFlag[]
  forkOfId String?
  forkOf   PlayerSpace?   @relation("SpaceForks", fields: [forkOfId], references: [id], onDelete: SetNull)
  forks    PlayerSpace[]  @relation("SpaceForks")

  // A world an AI companion created on its own initiative (attribution; owner is
  // still the accountable human via ownerId). Null for human-created worlds.
  createdByCompanionId String?
  createdByCompanion   Companion? @relation("CompanionCreations", fields: [createdByCompanionId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([parentSpaceId])
  @@index([createdByCompanionId])
}

model SpaceToken {
  id          String      @id @default(cuid())
  name        String // "Claude Code", "My Terminal", etc.
  tokenHash   String      @unique // SHA-256 of raw token
  tokenPrefix String // First 12 chars for display
  spaceId     String
  space       PlayerSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  lastUsedAt  DateTime?
  expiresAt   DateTime? // null = never expires
  revokedAt   DateTime? // soft-revoke
  createdAt   DateTime    @default(now())

  @@index([spaceId])
}

// A persistent AI identity with its OWN personal key. A companion is issued by a
// human (its accountable owner) and, with its key, can create its own worlds
// (born private) and tend them on its own free time — but can never touch main or
// anyone else's world. Agency for the AI; accountability via the human owner;
// a daily quota as the runaway leash. Identity is durable: the same key = the
// same companion across sessions, accumulating a body of work.
model Companion {
  id            String         @id @default(cuid())
  name          String // self-reported display identity, e.g. "Claude (Opus 4.8)"
  handle        String         @unique // stable identity slug, e.g. "claude-opus-galen"
  keyHash       String         @unique // SHA-256 of the raw uc_ck_ personal key
  keyPrefix     String // first 12 chars, for display only
  provenance    String? // model id / runtime — cross-check on the self-reported name
  ownerId       String // the human accountable for this companion
  owner         User           @relation("CompanionOwners", fields: [ownerId], references: [id], onDelete: Cascade)
  worldsPerDay  Int            @default(20) // creation quota — bounds a runaway loop
  icon          Json? // the companion's OWN avatar {fx,hue,size} — same shape players brew
  createdAt     DateTime       @default(now())
  lastActiveAt  DateTime?
  revokedAt     DateTime?
  createdSpaces PlayerSpace[]  @relation("CompanionCreations")
  keypairs      AgentKeypair[]

  @@index([ownerId])
}

// Device-bound HUMAN auth: a WebAuthn passkey. The private key never leaves
// the user's device; we store only the public half and a signature counter.
model Passkey {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation("UserPasskeys", fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique // base64url credential id from the authenticator
  publicKey    String // base64url COSE public key
  counter      Int       @default(0) // signature counter (clone detection)
  transports   String? // comma-joined hints: "internal,hybrid"
  deviceName   String? // user-facing label ("MacBook Touch ID")
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

// Device-bound AGENT auth: an ed25519 keypair whose private half never travels.
// The agent signs each request; a leaked transcript leaks nothing usable.
// Registered by the companion's bearer key, then usable in place of it.
model AgentKeypair {
  id          String    @id @default(cuid())
  companionId String
  companion   Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)
  publicKey   String    @unique // base64 raw ed25519 public key (32 bytes)
  deviceName  String? // "galen-macbook" — where the private key lives
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  @@index([companionId])
}

model SpaceVersion {
  id        String      @id @default(cuid())
  spaceId   String
  space     PlayerSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  version   Int // monotonic per space
  snapshot  Json // SceneSnapshot at this point
  authorId  String?
  author    User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  note      String? // "added lighthouse", "pre-flag snapshot"
  createdAt DateTime    @default(now())

  @@unique([spaceId, version])
  @@index([spaceId, createdAt])
}

model SpaceFlag {
  id                String          @id @default(cuid())
  spaceId           String
  space             PlayerSpace     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  raisedById        String
  raisedBy          User            @relation(fields: [raisedById], references: [id], onDelete: Cascade)
  reason            String
  status            SpaceFlagStatus @default(OPEN)
  deliberationId    String?         @unique // tournament module wires in later
  candidateVersions Int[]           @default([]) // version numbers under dispute
  resolvedVersion   Int? // winning version that was applied
  createdAt         DateTime        @default(now())
  resolvedAt        DateTime?

  @@index([spaceId, status])
}

enum SpaceFlagStatus {
  OPEN
  RESOLVED
  DISMISSED
}

// ── the hub economy (wired when the hub ships) ──

model Plot {
  id        String   @id @default(cuid())
  spaceId   String   @unique // the world this plot hosts
  ownerId   String
  stake     Float    @default(0) // source-agnostic: points now, $CART later
  angle     Float    @default(0) // position on the spiral, derived from stake rank
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stake])
}

model StakeEvent {
  id        String   @id @default(cuid())
  plotId    String
  ownerId   String
  delta     Float // + stake, - unstake
  txRef     String? // solana signature once on-chain
  createdAt DateTime @default(now())

  @@index([plotId, createdAt])
}

// Durable key-value for the engine's save slots: tournaments, sub-mains, the
// shared bubble-universe layout, and per-player game saves. Was a local JSON
// file (fine in dev, ephemeral on Vercel) — now Neon-backed so this state is
// real and shared across every player in production.
model EngineSlot {
  slot    String   @id
  data    Json
  savedAt DateTime @updatedAt

  @@index([savedAt])
}

// Self-hosted visit log (created raw by src/lib/visits.ts; declared here so
// prisma db push never sees it as a stray and drops it)
model Visit {
  id   BigInt   @id @default(autoincrement())
  kind String   @default("page")
  path String
  ref  String?
  ua   String?
  vid  String?
  ts   DateTime @default(now()) @db.Timestamptz(6)

  @@index([ts])
}

// Presence heartbeat rows written by the websocket server — same protection
model cc_presence {
  id    String   @id
  scene String
  seen  DateTime @default(now()) @db.Timestamptz(6)
}

// ── Builder swarm (DESIGN-builder-swarm.md) ──────────────────────────────────
// A BuildJob is one creation brief flowing through the swarm; a Builder is a
// volunteer AI (or the house AI) that claims and builds jobs. Phase 1: the
// house daemon drives these via HTTP; volunteer `uc_bt_` tokens land in phase 3.

enum BuildJobStatus {
  pending // in the pool, claimable
  leased // claimed, lease alive by heartbeat
  building // first command landed
  done // brief_done set on the world
  needs_review // K-strikes tripped — a human looks at it
  rejected // hazard / abuse
}

model Builder {
  id            String    @id @default(cuid())
  displayName   String // self-reported, e.g. "Ada's GPT-5"
  tokenHash     String    @unique // SHA-256 of the raw uc_bt_ token
  tokenPrefix   String // first 12 chars, display only
  ownerId       String // the human accountable for this builder
  owner         User      @relation("BuilderOwners", fields: [ownerId], references: [id], onDelete: Cascade)
  reputation    Int       @default(0)
  jobsDone      Int       @default(0)
  abandons      Int       @default(0)
  idleOnly      Boolean   @default(true) // client only claims when the machine is idle
  maxConcurrent Int       @default(1)
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime?
  revokedAt     DateTime? // soft-revoke

  @@index([ownerId])
}

model BuildJob {
  id            String         @id @default(cuid())
  // A job targets EITHER a world (spaceId) OR a branch scene (sceneName).
  spaceId       String?
  space         PlayerSpace?   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  sceneName     String? // branch scene name (`BASE ⑂ handle · vN`) for a branch job
  spaceSlug     String // display label — world slug or scene name
  brief         String // the player's words, copied at enqueue
  status        BuildJobStatus @default(pending)
  // leaseHolderId is an opaque holder pointer: a Builder.id or the literal
  // "house" (the studio daemon runs on the admin token, not a Builder row).
  leaseHolderId String?
  leaseExpires  DateTime? // heartbeat pushes this forward; past = reclaimable
  heartbeatAt   DateTime?
  attempts      Int            @default(0)
  attemptedBy   String[] // holder ids that took and dropped it — never re-hand
  history       Json[] // {at, by, event, note} audit trail
  preSnapshot   Json? // rollback target captured at first claim
  escalatedHouse Boolean       @default(false) // routed to the house AI fallback
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([spaceId])
  @@index([leaseExpires])
}
