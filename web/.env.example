# ── cartridge.cafe ──
# Database: create via Vercel dashboard → new project → Storage → Neon.
# Vercel injects DATABASE_URL automatically in deploys; copy it here for local dev.
DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=          # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Engine
ENGINE_AGENT_TOKEN=       # openssl rand -hex 16 — the master agent key (per-world tokens are minted in-app)

# Built-in AI builder
ANTHROPIC_API_KEY=

# Admin
ADMIN_EMAILS=
